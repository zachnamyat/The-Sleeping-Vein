; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="The Sleeping Vein"
config/description="A 2D top-down survival / mining / exploration game.
Working lore title: AETHERDEEP — The Sunken Aeon.
Mechanical-parity-then-extend approach: replicate Core Keeper's
core systems on top of original lore, then layer custom features."
run/main_scene="res://scenes/ui/title_screen.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="res://assets/sprites/ui/game_icon.png"

[autoload]

GameState="*res://scripts/autoloads/game_state.gd"
EventBus="*res://scripts/autoloads/event_bus.gd"
SaveSystem="*res://scripts/autoloads/save_system.gd"
AudioBus="*res://scripts/autoloads/audio_bus.gd"
SkillSystem="*res://scripts/systems/skill_system.gd"
TalentRegistry="*res://scripts/systems/talent_registry.gd"
ItemRegistry="*res://scripts/systems/item_registry.gd"
Inventory="*res://scripts/systems/inventory.gd"
MiningSystem="*res://scripts/systems/mining.gd"
CraftingSystem="*res://scripts/systems/crafting.gd"
NpcDirector="*res://scripts/systems/npc_director.gd"
Compendium="*res://scripts/systems/compendium.gd"
BossDirector="*res://scripts/systems/boss_director.gd"
NetSystem="*res://scripts/systems/multiplayer.gd"
FarmingSystem="*res://scripts/systems/farming.gd"
Buffs="*res://scripts/systems/buffs.gd"
BiomeHazard="*res://scripts/systems/biome_hazard.gd"
Achievements="*res://scripts/systems/achievements.gd"
FishingSystem="*res://scripts/systems/fishing.gd"
Housing="*res://scripts/systems/housing.gd"
I18n="*res://scripts/systems/i18n.gd"
Settings="*res://scripts/systems/settings_persistence.gd"
CombatFeel="*res://scripts/systems/combat_feel.gd"
PlayerStats="*res://scripts/systems/player_stats.gd"
LuckSystem="*res://scripts/systems/luck_system.gd"
SkillChallenges="*res://scripts/systems/skill_challenges.gd"
CombatTracker="*res://scripts/systems/combat_tracker.gd"
WorldEvents="*res://scripts/systems/world_events.gd"
CrystalRegrowth="*res://scripts/world/crystal_regrowth.gd"
TutorialDirector="*res://scripts/systems/tutorial_director.gd"
BarkSystem="*res://scripts/systems/bark_system.gd"
TitleSystem="*res://scripts/systems/title_system.gd"
CookingSystem="*res://scripts/systems/cooking.gd"
Critters="*res://scripts/systems/critters.gd"
Pets="*res://scripts/systems/pets.gd"
NpcLifecycle="*res://scripts/systems/npc_lifecycle.gd"
Phase9Helpers="*res://scripts/systems/phase9_helpers.gd"
Phase10Helpers="*res://scripts/systems/phase10_helpers.gd"
Phase11Helpers="*res://scripts/systems/phase11_helpers.gd"
DevConsole="*res://scripts/autoloads/dev_console.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=270
window/size/window_width_override=1920
window/size/window_height_override=1080
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/ai_pixel_art_generator/plugin.cfg", "res://addons/gut/plugin.cfg")

[gui]

theme/custom="res://resources/themes/sleeping_vein.tres"

