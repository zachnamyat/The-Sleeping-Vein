[resource]
script = ExtResource("1_def")
id = &"resurrection_altar_placeable"
display_name = "Resurrection Altar"
description = "Place near the Anchor in multiplayer worlds. Lets one Walker spend an Aphelion sliver to immediately revive a fallen ally instead of waiting for the respawn timer."
icon = ExtResource("2_icon")
max_stack = 1
item_type = 5
tier = 8
rarity = 4
lore_text = "Loom-Twin etched the first one in a single Beat. The dead refuse to stay dead when you ask gently."
lore_ref = "lore/07_walkers.md"
