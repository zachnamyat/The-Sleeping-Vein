[gd_resource type="Resource" script_class="Recipe" format=3 uid="uid://rec0bugnet"]

[ext_resource type="Script" path="res://scripts/resources/recipe.gd" id="1_rec"]

[resource]
script = ExtResource("1_rec")
id = &"craft_bug_net"
display_name = "Bug Net"
inputs = [{ "item_id": "wood", "count": 2 }, { "item_id": "heartwood", "count": 1 }]
