[gd_resource type="Resource" script_class="Recipe" format=3 uid="uid://rec0driedmeat"]

[ext_resource type="Script" path="res://scripts/resources/recipe.gd" id="1_rec"]

[resource]
script = ExtResource("1_rec")
id = &"craft_dried_meat"
