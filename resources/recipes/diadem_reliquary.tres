[gd_resource type="Resource" script_class="Recipe" format=3 uid="uid://crecreliq12"]

[ext_resource type="Script" path="res://scripts/resources/recipe.gd" id="1_rec"]

[resource]
script = ExtResource("1_rec")
id = &"craft_diadem_reliquary"
display_name = "Diadem Reliquary"
inputs = [{ "item_id": "diadem_gold_ore", "count": 8 }, { "item_id": "aphelion_shard", "count": 3 }, { "item_id": "auroric_ice_ore", "count": 12 }, { "item_id": "ember_iron_ore", "count": 12 }]
outputs = [{ "item_id": "diadem_reliquary_placeable", "count": 1 }]
stations = [&"auroric_anvil"]
skill_xp_grant = 90
skill_xp_id = &"skill_crafting"
description = "Smelts Diadem-Gold and converts lower-tier ores at a 4:1 ratio."
