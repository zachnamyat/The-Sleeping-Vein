[gd_resource type="Resource" script_class="Recipe" format=3 uid="uid://rec0aquarium"]

[ext_resource type="Script" path="res://scripts/resources/recipe.gd" id="1_rec"]

[resource]
script = ExtResource("1_rec")
id = &"craft_aquarium"
display_name = "Aquarium"
inputs = [{ "item_id": "plank", "count": 2 }, { "item_id": "bottle_empty", "count": 1 }]
outputs = [{ "item_id": "aquarium_placeable", "count": 1 }]
stations = [&"loam_bench"]
skill_xp_grant = 3
skill_xp_id = &"skill_crafting"
