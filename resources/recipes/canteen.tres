[gd_resource type="Resource" script_class="Recipe" format=3 uid="uid://rec0canteen"]

[ext_resource type="Script" path="res://scripts/resources/recipe.gd" id="1_rec"]

[resource]
script = ExtResource("1_rec")
id = &"craft_canteen"
display_name = "Canteen"
inputs = [{ "item_id": "bottle_empty", "count": 1 }, { "item_id": "wood", "count": 1 }]
outputs = [{ "item_id": "canteen", "count": 1 }]
stations = [&"loam_bench"]
skill_xp_grant = 1
skill_xp_id = &"skill_crafting"
