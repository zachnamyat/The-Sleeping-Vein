[gd_resource type="Resource" script_class="Recipe" format=3 uid="uid://rec0beehive"]

[ext_resource type="Script" path="res://scripts/resources/recipe.gd" id="1_rec"]

[resource]
script = ExtResource("1_rec")
id = &"craft_beehive"
display_name = "Beehive"
inputs = [{ "item_id": "plank", "count": 3 }, { "item_id": "heart_berry", "count": 2 }]
